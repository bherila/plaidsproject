msgstr "Деактивированный"

#: .././maintenance-mode.php:132
#: .././maintenance-mode.php:139
msgid "Message"
msgstr "Сообщение"

#: .././maintenance-mode.php:135
msgid "Title"
msgstr "Заголовок"

#: .././maintenance-mode.php:141
msgid "Use HTML only, no PHP allowed. You can use <strong>[blogurl]</strong>, <strong>[blogtitle]</strong> and <strong>[backtime]</strong> as placeholders."
msgstr "Использовать только HTML, без PHP. Вы можете использовать <strong>[blogurl]</strong>, <strong>[blogtitle]</strong> и <strong>[backtime]</strong> как якоря."

#: .././maintenance-mode.php:147
msgid "Backtime and HTTP header"
msgstr "Backtime и HTTP-заголовок"

#: .././maintenance-mode.php:150
msgid "Backtime in minutes"
msgstr "Backtime в минутах"

#: .././maintenance-mode.php:152
msgid "A special HTML header for feed and trackback will be applied (&laquo;503 Service Unavailable&raquo;) including 'retry after x minutes'. Enter here the approximate time in minutes to retry. Also, by using the placeholder <strong>[backtime]</strong> above, the time in minutes be displayed to the visitors as well."
msgstr "A special HTML header for feed and trackback will be applied (&laquo;503 Service Unavailable&raquo;) including 'retry after x minutes'. Enter here the approximate time in minutes to retry. Also, by using the placeholder <strong>[backtime]</strong> above, the time in minutes be displayed to the visitors as well."

#: .././maintenance-mode.php:157
msgid "Apply HTTP header '503 Service Unavailable' and 'Retry-After &lt;backtime&gt;' to Maintenance Mode splash page"
msgstr "Apply HTTP header '503 Service Unavailable' and 'Retry-After &lt;backtime&gt;' to Maintenance Mode splash page"

#: .././maintenance-mode.php:161
msgid "Paths to be still accessable"
msgstr "Доступные пути"

#: .././maintenance-mode.php:163
msgid "Enter paths that shall be excluded and still be accessable. Separate multiple paths with line breaks.<br />Example: If you want to exclude <em>http://site.com/about/</em>, then enter <em>/about/</em>."
msgstr "Enter paths that shall be excluded and still be accessable. Separate multiple paths with line breaks.<br />Example: If you want to exclude <em>http://site.com/about/</em>, then enter <em>/about/</em>."

#: .././maintenance-mode.php:168
msgid "How to permit blog editors to see the blog's front-end"
msgstr "How to permit blog editors to see the blog's front-end"

#: .././maintenance-mode.php:169
msgid "As soon as you activate the maintenance mode, a splash page is being added to your blog that informs visitors about your blog maintenance. Logged in administrators get full access to the blog including the front-end and will not see any splash page.<br />This plugin adds the capability 'access_on_maintenance' to the role 'Administrator'. If users with a specific role, for instance 'Editor', should get full access to the blog as well, use an appropriate plugin like"
msgstr "As soon as you activate the maintenance mode, a splash page is being added to your blog that informs visitors about your blog maintenance. Logged in administrators get full access to the blog including the front-end and will not see any splash page.<br />This plugin adds the capability 'access_on_maintenance' to the role 'Administrator'. If users with a specific role, for instance 'Editor', should get full access to the blog as well, use an appropriate plugin like"

#: .././maintenance-mode.php:171
msgid "and grant the capability 'Access On Maintenance' for the role 'Editor' or for any other role of your choice. <br />Check out"
msgstr "and grant the capability 'Access On Maintenance' for the role 'Editor' or for any other role of your choice. <br />Check out"

#: .././maintenance-mode.php:173
msgid "for further information."
msgstr "для дальнейшей информации."

